{
    "name": "aryeo/api-resource-schema",
    "type": "library",
    "repositories": {
        "tooling-laravel": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/tooling-laravel"
        }
    },
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.37",
        "symfony/console": "^7.0",
        "phpstan/phpstan": "^2.1",
        "nikic/php-parser": "^5.7",
        "aryeo/tooling-laravel": "0.0.31"
    },
    "require-dev": {
        "orchestra/testbench": "^10.6",
        "brianium/paratest": "^7.14",
        "phpunit/phpunit": "^12.4.1",
        "pestphp/pest": "^4.1",
        "orchestra/testbench-core": "^10.7",
        "nesbot/carbon": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Support\\": "src/Support",
            "Tooling\\": "src/Tooling/"
        },
        "exclude-from-classmap": [
            "*Test.php",
            "*TestCases.php",
            "/tests/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Justin Seliga",
            "email": "justinsel@zillowgroup.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "aryeo/tooling-laravel": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Support\\Http\\Resources\\Schemas\\Providers\\Provider"
            ]
        },
        "tooling": {
            "rector": {
                "configured_rules": "tooling/rector/configured-rules.php"
            },
            "phpstan": "tooling/phpstan/phpstan.neon"
        }
    }
}
